AIRIA_API_KEY=your_airia_api_key
AIRIA_PIPELINE_ID=06713078-ed36-4316-a783-dd89e562ae07
AIRIA_WEBHOOK_URL=https://api.airia.ai/v1/webhook/your-webhook-id/your-secret

# Optional Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# Alternative to webhook:
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#incident-response

# Optional Microsoft Teams
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx/IncomingWebhook/yyy/zzz

# Optional Slack Approval Cards (manual route pending notifications)
APPROVAL_APPROVE_URL_TEMPLATE=https://your-approve-host/approve?execution_id={execution_id}
APPROVAL_DENY_URL_TEMPLATE=https://your-approve-host/deny?execution_id={execution_id}
SLACK_SIGNING_SECRET=your_slack_signing_secret
AIRIA_APPROVAL_CALLBACK_URL=https://your-approval-resume-endpoint

# Optional Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_token
JIRA_PROJECT_KEY=PROJ

# Optional Asana
ASANA_PAT=your_asana_personal_access_token
ASANA_PROJECT_GID=1200000000000000

# Optional SMTP email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=you@company.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=you@company.com
EMAIL_TO=team@company.com;manager@company.com
